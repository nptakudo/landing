# Override with the absolute path to your real Obsidian vault for local authoring.
# When unset, the sync scripts fall back to the repo-local example content.
OBSIDIAN_VAULT_PATH=content/example

# The canonical site URL. site.config.ts uses this override at build time.
SITE_URL=https://example.com

# Required for .github/workflows/deploy-vercel.yml
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Optional separate-vault deployment inputs.
VAULT_REPO=
VAULT_REF=main
VAULT_REPO_TOKEN=
