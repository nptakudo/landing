# Override with the absolute path to your real Obsidian vault for local authoring.
# The repo-local example content keeps CI and first-run previews deterministic.
OBSIDIAN_VAULT_PATH=content/example

# The current app reads the canonical URL from site.config.ts.
# Keep SITE_URL aligned with that value for deploy automation and future config parity.
SITE_URL=https://example.com

# Required for .github/workflows/deploy-vercel.yml
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Optional separate-vault deployment inputs.
VAULT_REPO=
VAULT_REF=main
VAULT_REPO_TOKEN=
