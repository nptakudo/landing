{
  "name": "landing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "content:mirror": "bun run scripts/sync-vault.mts",
    "content:sync": "bun run content:mirror && bun run search:index && bun run graph:build && bun run feeds:build",
    "content:watch": "bun run scripts/watch-vault.mts",
    "search:index": "bun run scripts/build-search-index.mts",
    "graph:build": "bun run scripts/build-graph.mts",
    "feeds:build": "bun run scripts/build-feeds.mts",
    "prebuild": "bun run content:sync",
    "dev": "next dev",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0-beta.4",
    "chokidar": "^4.0.3",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "date-fns": "^4.1.0",
    "fast-glob": "^3.3.3",
    "github-slugger": "^2.0.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.553.0",
    "minisearch": "^7.2.0",
    "motion": "^12.23.24",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "reading-time": "^1.5.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tailwind-merge": "^3.3.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
