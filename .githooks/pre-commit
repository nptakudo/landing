#!/usr/bin/env bash
set -euo pipefail

# Block commits that include likely secrets in staged text files.
SECRET_PATTERN='(vca_[A-Za-z0-9]{20,}|vcr_[A-Za-z0-9]{20,}|gh[pousr]_[A-Za-z0-9]{20,}|xox[baprs]-[A-Za-z0-9-]{10,}|AKIA[0-9A-Z]{16}|-----BEGIN (RSA |EC |OPENSSH |DSA )?PRIVATE KEY-----)'

staged_files=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$staged_files" ]; then
  exit 0
fi

found=0

while IFS= read -r file; do
  [ -z "$file" ] && continue

  # Skip binary files.
  if git diff --cached --numstat -- "$file" | awk '{print $1" "$2}' | grep -q '^- -$'; then
    continue
  fi

  if git show ":$file" | grep -En "$SECRET_PATTERN" >/tmp/pre-commit-secret-hits.txt; then
    echo "[pre-commit] Potential secret detected in staged file: $file" >&2
    cat /tmp/pre-commit-secret-hits.txt >&2
    found=1
  fi
done <<< "$staged_files"

if [ "$found" -eq 1 ]; then
  echo >&2
  echo "Commit blocked: remove or rotate detected secrets before committing." >&2
  echo "If this is a false positive, sanitize the value or split the file." >&2
  exit 1
fi

exit 0
